;;; -*- lexical-binding: t -*-
(setq auto-save-file-name-transforms '((".*" "~/.emacs.d/emacs-saves/" t)))
(setq lock-file-name-transforms '((".*" "~/.emacs.d/emacs-saves/" t)))
(setq backup-directory-alist '((".*" . "~/.emacs.d/emacs-saves/")))
(setq read-process-output-max (* 4 1024 1024))
(setq save-interprogram-paste-before-kill t)
(setq kill-do-not-save-duplicates t)
(menu-bar-mode 0)
(tool-bar-mode 0)
(scroll-bar-mode 0)
(savehist-mode 1)
(electric-pair-mode 1)
(delete-selection-mode 1)
(which-function-mode)
(editorconfig-mode)
(setq reb-re-syntax 'string)
(load-theme 'modus-vivendi t)
(global-set-key (kbd "C-,") #'xref-go-forward)
(global-set-key (kbd "C-c C-v") 'duplicate-dwim)
(which-key-mode 1)
(setq isearch-lazy-count t)
(setq completion-ignore-case t)
(fido-mode 1)
(setq completion-styles '(basic partial-completion substring initials flex))
(fset 'yes-or-no-p 'y-or-n-p)
(setq imenu-auto-rescan t)
(setq scroll-conservatively 20)
(setq set-mark-command-repeat-pop t)
(repeat-mode 1)
(recentf-mode 1)
(set-face-attribute 'mode-line-active nil :background "black")
(set-face-attribute 'mode-line-inactive nil :background "black")
(with-eval-after-load 'eglot (define-key eglot-mode-map (kbd "C-c C-f") 'eglot-format))
(setq search-whitespace-regexp ".*?")
