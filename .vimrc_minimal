vim9script
set nocompatible nobackup nowritebackup noswapfile noruler noshowmode noshowcmd
filetype plugin indent on
syntax on
set tabstop=2 shiftwidth=2 softtabstop=2 expandtab smartindent infercase
set completeopt=fuzzy,menuone,popup,noselect laststatus=- title
set wildmode=noselect:lastused,full wildoptions=pum wildcharm=<C-@>
set mouse=a incsearch hlsearch ignorecase smartcase showmatch
set completefunc=keyword,files,whole_line titlestring=%t\ -\ %l:%c\ (%p%%)
packadd! termdebug
packadd! nohlsearch
packadd! hlyank
packadd! editorconfig
packadd! comment
packadd! cfilter
packadd! osc52
g:mapleader = "\<Space>"
imap ş <Esc>
vmap ş <Esc>
cmap ş <Esc>
imap <C-k> <Up>
imap <C-j> <Down>
imap <C-h> <Left>
imap <C-l> <Right>
cmap <C-k> <Up>
cmap <C-j> <Down>
cmap <C-h> <Left>
cmap <C-l> <Right>
nmap <silent> gn :bn<CR>
nmap <silent> gp :bp<CR>
noremap <silent> gl $
noremap <silent> gh 0
noremap <silent> <leader>l :cnext<CR>
noremap <silent> <leader>h :cprev<CR>
nnoremap <silent> <C-k> :tabn<CR>
tnoremap <silent> <C-k> <C-w>:tabn<CR>
nnoremap <silent> <leader>g :tab term lazygit<CR>
nnoremap <silent> <C-a> :tab term bash<CR>
nnoremap <silent> <C-l> :nohlsearch<CR><C-l>
nmap <silent> s :ptag <C-r><C-w><CR>
